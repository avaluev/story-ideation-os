# story-ideation-os — environment template
# Copy to `.env` and replace every REPLACE-ME with a real value. `.env` is gitignored.
# The engine runs its offline layers (scoring, schema, frameworks, corpus matching)
# with NO keys at all; keys are only needed for the live research + dispatch layers.

# --- Model access ------------------------------------------------------------
# Anthropic (Claude) — primary dispatch path (ADR-0007).
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# OpenRouter — optional multi-model gateway. Three keys enable free/paid rotation
# with masked logging + quota gating (ADR-0003 / ADR-0008).
OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME
OPENROUTER_KEY_PAID=sk-or-v1-REPLACE-ME-PAID
OPENROUTER_KEY_FREE_1=sk-or-v1-REPLACE-ME-FREE-1
OPENROUTER_KEY_FREE_2=sk-or-v1-REPLACE-ME-FREE-2

# --- Evidence / research gateways (optional; used by the veracity layer) ------
EXA_API_KEY=REPLACE-ME
SERPER_API_KEY=REPLACE-ME
JINA_API_KEY=REPLACE-ME
AIML_API_KEY=REPLACE-ME
TAO_AI_API_KEY=REPLACE-ME
TMDB_API_KEY=REPLACE-ME

# Gateway routing toggles (1 = on).
AIML_PRIMARY=0
TAO_AI_PRIMARY=0

# --- Budget guardrails (hard caps in USD; digit-only) ------------------------
DAILY_USD_CAP=15
MONTHLY_USD_CAP=200

# --- Tuning knobs (optional; sane defaults applied when unset) ----------------
RESEARCH_MAX_CONCURRENCY=4
OPENROUTER_HTTP_TIMEOUT_S=60
VERACITY_PROBE_TIMEOUT=20
PHASE_3_SONAR_CALL_CAP=8
# Set to 1 ONLY in tests to bypass the quota gate. Never in production.
ANOMALY_QUOTA_DISABLED=0
