# --- Secrets & inputs that contain plaintext keys ----------------------------
# Inputs/_ANOMALY_ENGINEv3.0.md contains 3 plaintext OpenRouter API keys
# (sk-or-v1-...). Until those keys are rotated and the doc is sanitized,
# the entire Inputs/ tree is excluded from git EXCEPT the v3.1 framework files
# which contain no secrets (machine-readable contracts and protocols only).
# NOTE: use `Inputs/*` (not `Inputs/`) so the negations below actually re-include
# the whitelisted files — git cannot re-include children of a fully-excluded dir.
Inputs/*
!Inputs/MASTER_BRIEF.md
!Inputs/CONCEPT_TEMPLATE.md
!Inputs/RESEARCH_PROTOCOL.md
!Inputs/CHALLENGE_PROTOCOL.md
!Inputs/INTELLECTUAL_FRAMEWORK.md
!Inputs/CONCEPT_TEMPLATE_V2.md
!Inputs/STYLE_GUIDE.md
.env
.env.*
!.env.example
*.key
*.pem
secrets/
.secrets
credentials.json
.netrc

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.pyright/
.ruff_cache/
.hypothesis/
*.egg

# --- Data + runtime outputs (engine-specific) -------------------------------
# data/* (rather than data/) excludes only direct children; allows whitelisting subdirs.
data/*
data/state/       # runtime state per MEM-11 (gitignored; .planning/state/ is tracked)
# pipeline/data/ is a tracked framework-data directory (oblique_strategies.json etc.)
!pipeline/data/
# v3.1 redesign: seed CSVs + knowledge corpora + glossary are tracked project content
!data/seeds/
!data/knowledge_base/
!data/glossary_master.json
# out/* (rather than out/) so we can whitelist tracked subdirs below.
out/*
!out/.gitkeep
# v3.1 Path C deliverable: tracked production output (1000+ unique stories).
!out/concepts/
out/concepts/*
!out/concepts/v3.1-pathc/
!out/concepts/v3.1-pathc-a4/
!out/index.html
!out/best_concepts.html
!out/EXECUTIVE_SUMMARY.md
*.jsonl
!examples/golden/*.jsonl
!tests/fixtures/*.jsonl
!tests/golden_concepts.jsonl
# planning-state JSONL logs are git-tracked per MEM-11
!.planning/state/*.jsonl
# NB.3 anti-orphan artifact gate; required by scripts/check_consumer_map.py
!data/_consumers.jsonl
# NB.5 runtime composer; empty in Cycle 1 (rules emitted by S4 discovery notebook)
!data/axis_selection_rules.jsonl
# v6.0 E3a corpus enrichment cache; empty placeholder until operator runs scripts/enrich_films_corpus.py
!pipeline/data/films_corpus_enriched.jsonl
# v7.0 F0 cross-run leaderboard history; empty placeholder until operator runs `python -m pipeline.leaderboard --rebuild`
!data/leaderboard.jsonl
# v7.0 F0.2 Google-Sheets-friendly CSV export of the leaderboard; same rebuild flow
!data/leaderboard.csv
# Top-N ideas deliverables (regenerated by scripts/top_ideas.py)
!data/top_ideas_*.md
!data/top_ideas_*.csv
*.tar.gz
audit_report_*.md

# Transient /evolve outputs. The single-idea runs at runs/<date>-<slug>/ ARE
# tracked (operator-curated NARRATOR.md sessions); /evolve runs accumulate
# every CLI invocation and are summarised into data/leaderboard.{csv,jsonl}.
runs/evolve-*/
# Transient multi-format slate run JSON (regenerated by scripts/run_format_slate.py;
# the rendered deliverable lives at outputs/slate/INVESTOR_SLATE_EN.md).
runs/format-slate/

